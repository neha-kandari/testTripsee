# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temporary files
*.tmp
*.temp
*_fix.js
*_backup.*
temp_*
test-*
*.backup

# Large video files — served from Cloudinary, not the VPS.
# Keep them locally for development reference but never push to git.
public/videos/*.mp4
public/assets/*.mp4
public/assets/*.webm
public/Feedback/*.mp4
public/Feedback/*.webm
*.mp4
*.webm
